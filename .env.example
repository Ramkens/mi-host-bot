# Telegram
BOT_TOKEN=000000:replace_me
ADMIN_IDS=8341143485

# Public base URL (set after first Render deploy, used for webhooks)
PUBLIC_URL=https://mi-host-bot.onrender.com
WEBHOOK_PATH=/tg/webhook
WEBHOOK_SECRET=change_me_random

# Channel autopilot (optional). Bot must be admin.
CHANNEL_ID=
CHAT_ID=

# Postgres
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# CryptoBot (https://t.me/CryptoBot)
CRYPTOBOT_TOKEN=
CRYPTOBOT_WEBHOOK_SECRET=

# Render (https://dashboard.render.com/u/settings#api-keys)
RENDER_API_KEY=
RENDER_OWNER_ID=
RENDER_REGION=frankfurt
RENDER_PLAN=free

# cron-job.org (https://console.cron-job.org/settings)
CRONJOB_API_KEY=

# Optional: OpenAI for content generation (falls back to local templates if absent)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
TZ=Europe/Moscow
LOG_LEVEL=INFO
SUBSCRIPTION_DAYS=30
PRICE_CARDINAL_RUB=40
PRICE_SCRIPT_RUB=50
MINIGAME_COOLDOWN_HOURS=12
MINIGAME_BONUS_DAYS=1
REFERRAL_BONUS_DAYS=3
SECRET_KEY=change_me_random_long_string
